# ============================================
# Config Center System - 环境变量模板
# 复制此文件为 .env 并填入真实值。
# 注意: .env 不应提交到 git（已在 .gitignore 中）
# ============================================

# MySQL 配置
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=config_center
MYSQL_USER=config_user
MYSQL_PASSWORD=change_me_user_password
MYSQL_ROOT_HOST=%

# MySQL 应用连接
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/config_center?useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=config_user
SPRING_DATASOURCE_PASSWORD=change_me_user_password
SPRING_DATASOURCE_HOST=mysql

# Redis 配置
REDIS_PASSWORD=change_me_redis_password
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_DATABASE=0
SPRING_REDIS_PASSWORD=change_me_redis_password

# 应用端口
SERVER_PORT=8080

# Security 配置
# ⚠️ 生产环境必须修改！未设置或设为 "admin" 时启动会生成随机 bootstrap token 打印到日志
CC_ADMIN_PASSWORD=change_me_admin_password
CC_USER_PASSWORD=change_me_user_password
# CORS 允许的来源（逗号分隔，* 表示允许所有）
CC_CORS_ALLOWED_ORIGINS=*
